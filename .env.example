# Veridium Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Blockchain Configuration
# ============================================
# Monad Testnet RPC (default)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Contract Addresses (fill after deployment)
TOKEN_ADDRESS=
ESCROW_ADDRESS=
PAYMENT_VAULT_ADDRESS=
KAWAI_DISTRIBUTOR_ADDRESS=
USDT_DISTRIBUTOR_ADDRESS=

# ============================================
# Economic Configuration (Two-Phase Model)
# ============================================
# Phase 1: KAWAI minted per 1 Million tokens processed
KAWAI_RATE_PER_MILLION=100

# Phase 2: USDT cost per 1 Million tokens processed
COST_RATE_PER_MILLION=1.0

# ============================================
# Admin Configuration
# ============================================
# Admin wallet address for fee collection (30% split)
ADMIN_ADDRESS=

# Private key for signing Merkle Root updates (DO NOT COMMIT!)
# ADMIN_PRIVATE_KEY=

# ============================================
# Cloudflare Workers KV (Data Storage)
# ============================================
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_KV_NAMESPACE_ID=

# ============================================
# Optional: Jarvis Network Override
# ============================================
# Override default RPC node for Monad
# MONAD_TESTNET_NODE=https://testnet-rpc.monad.xyz
