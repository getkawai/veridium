# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# RPC URL for Monad Testnet
RPC_URL=https://testnet-rpc.monad.xyz

# Contract addresses (fill after deployment)
# Current deployed contracts (OLD VERSION - before partial fill upgrade):
# - KawaiToken: 0x3EC7A3b85f9658120490d5a76705d4d304f4068D
# - OTCMarket (Escrow): 0x134244eDd4349b0B408c5293Ffb4263984F2808C
#
# After deploying NEW version with partial fill support:
# Run: make contracts-deploy-testnet
# Then copy the NEW address here:
CONTRACT_ADDRESS=0x...  # NEW OTCMarket contract address (after upgrade deployment)

# Etherscan API key (for contract verification)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Monad Testnet Chain ID (DO NOT CHANGE)
CHAIN_ID=10143
